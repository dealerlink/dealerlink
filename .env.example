# ============================================================================
# Dealerlink — Local Development Environment
# ============================================================================
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored; .env.example is committed.
# ============================================================================
# --- Database -----------------------------------------------------------------
# DATABASE_URL: app runtime connection. Uses dealerlink_app — a NOLOGIN-NOBYPASSRLS
# role so RLS policies are enforced against tenant context.
# DATABASE_DIRECT_URL: migrations + seeds + studio. Uses dealerlink (superuser).
DATABASE_URL=postgresql://dealerlink_app:dev_app_password_change_me@localhost:5432/dealerlink_dev
DATABASE_DIRECT_URL=postgresql://dealerlink:dev_password_change_me@localhost:5432/dealerlink_dev
# --- Auth ---------------------------------------------------------------------
# Generate with PowerShell:
#   -join ((1..32) | ForEach-Object { '{0:x2}' -f (Get-Random -Maximum 256) })
# OR if openssl is available:
#   openssl rand -hex 32
SESSION_SECRET=replace_with_64_char_hex_string
# --- Email (Resend) -----------------------------------------------------------
# Get from https://resend.com/api-keys (free tier is fine for dev)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# Server-only secret that signs/verifies inbound Resend webhook events.
# Dev: generate any value — node -e "console.log('whsec_'+require('crypto').randomBytes(32).toString('base64url'))"
# Prod: use the signing secret Resend shows when you create the webhook endpoint.
# NEVER expose via a NEXT_PUBLIC_* variable.
RESEND_INBOUND_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=onboarding@resend.dev
# --- Errors (Sentry) ----------------------------------------------------------
# All Sentry SDKs gracefully no-op when the DSN is blank, so dev runs without
# Sentry configured. Get DSNs from https://sentry.io (projects dealerlink-web,
# dealerlink-workers). SENTRY_DSN is server-only (web server + workers);
# NEXT_PUBLIC_SENTRY_DSN is inlined into the browser bundle.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ENVIRONMENT=development
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
# Release identifier — tag events + the /health `version` field. Usually the
# git SHA, injected by CI at deploy time.
SENTRY_RELEASE=
NEXT_PUBLIC_SENTRY_RELEASE=
# Optional — only needed for source-map upload at build time (CI).
# SENTRY_AUTH_TOKEN=
# --- Logs (Better Stack) ------------------------------------------------------
# Structured logs ship to Better Stack in production only. When the source
# token is blank, pino pretty-prints to stdout (dev) / writes JSON to stdout
# (prod, picked up by DO Logs). Create a source at https://betterstack.com.
BETTERSTACK_SOURCE_TOKEN=
# BETTERSTACK_INGESTING_HOST=s1234567.eu-nbg-2.betterstackdata.com
# --- App ----------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
# --- File Storage (deferred until shipping) -----------------------------------
# DO_SPACES_KEY=
# DO_SPACES_SECRET=
# DO_SPACES_BUCKET=
# DO_SPACES_REGION=blr1
# --- Event analytics (Axiom) --------------------------------------------------
# Business events (logins, quotations, payments…) ship to Axiom in production.
# When unset, trackEvent() logs the event via pino instead. AXIOM_DATASET is
# the destination dataset; AXIOM_TOKEN is an ingest-scoped API token.
AXIOM_TOKEN=
AXIOM_DATASET=dealerlink-events