{
  "name": "@dealerlink/db",
  "version": "0.1.0",
  "private": true,
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint --max-warnings=0 --no-error-on-unmatched-pattern .",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/migrate.ts",
    "db:rollback": "drizzle-kit drop",
    "db:seed": "tsx src/seeds/index.ts && tsx src/seeds/day5.ts && tsx src/seeds/day6.ts && tsx src/seeds/day7.ts && tsx src/seeds/day8.ts && tsx src/seeds/day11.ts && tsx src/seeds/day12.ts",
    "db:seed:base": "tsx src/seeds/index.ts",
    "db:seed:day5": "tsx src/seeds/day5.ts",
    "db:seed:day6": "tsx src/seeds/day6.ts",
    "db:seed:day7": "tsx src/seeds/day7.ts",
    "db:seed:day8": "tsx src/seeds/day8.ts",
    "db:seed:day11": "tsx src/seeds/day11.ts",
    "db:seed:day12": "tsx src/seeds/day12.ts",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@node-rs/argon2": "^2.0.2",
    "drizzle-orm": "^0.38.3",
    "pg": "^8.13.1",
    "postgres": "^3.4.5",
    "@dealerlink/tax": "workspace:*"
  },
  "devDependencies": {
    "@types/pg": "^8.11.10",
    "dotenv": "^16.4.7",
    "drizzle-kit": "^0.30.1",
    "tsx": "^4.19.2",
    "typescript": "*",
    "vitest": "^2.1.8"
  }
}
